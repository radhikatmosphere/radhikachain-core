# Copia a .env y rellena con tus credenciales locales.
# Nunca subas .env al repositorio.

# RPC del nodo RadhikaChain (local o vía túnel)
RPC_URL=http://127.0.0.1:8332
RPC_USER=
RPC_PASS=

# Wallet RPC (opcional; por defecto RPC_URL/wallet/<nombre>)
# RPC_WALLET_URL=http://127.0.0.1:8332/wallet/mi_wallet
RPC_WALLET_NAME=default

# Dirección coinbase (opcional; si vacío, el minero crea una nueva)
# MINER_ADDRESS=

# PoK / Karma
KARMA_SCORE=5000
BATCH_SIZE=10000
MINE_INTERVAL_SEC=30

# Consenso Prana (opcional; desactivado por defecto para mineros públicos)
ENFORCE_PRANA_CONSENSUS=false
# PRANA_ENGINE_URL=http://127.0.0.1:5000/status

# CLI del nodo (radhika-cli o bitcoin-cli en PATH)
CLI_BIN=radhika-cli

# Red
NETWORK=mainnet
RADHIKA_DIR=~/.radhika
LOG_LEVEL=info